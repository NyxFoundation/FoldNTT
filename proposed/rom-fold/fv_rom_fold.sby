[tasks]
bmc

[options]
# BMC only: every assertion reads at most one cycle back and the initial
# state is unconstrained, so depth-6 BMC covers every window of every
# execution — a complete unbounded proof by itself.  Plain k-induction
# does not converge here (frozen REN=0 windows admit spurious states)
# and adds nothing — same situation as the butterfly harnesses, see
# ../../yosys/README.md.
bmc: mode bmc
bmc: depth 6

[engines]
smtbmc yices

[script]
read -formal -sv fv_rom_fold.sv
read -formal tf_rom_fold.v
read -formal tf_ROM.v
prep -top fv_rom_fold

[files]
fv_rom_fold.sv
tf_rom_fold.v
../../cfntt_ref/hardware_code_radix-2/tf_ROM.v
